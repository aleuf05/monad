# ==============================================================================
# MONAD RUNTIME EXCLUSIONS
# ==============================================================================

# Ignore the virtual environment completely
.venv/
__pycache__/
*.pyc

# Block all automated agent and captain runtime logs
logs/agents/**/*.jsonl
logs/agents/**/*.log
logs/public-ready.log

# Exceptions: Allow tracking of foundational documentation/blueprints
!logs/captains/**/*.md
