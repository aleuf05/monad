# ==============================================================================
# MONAD RUNTIME EXCLUSIONS
# ==============================================================================

# Ignore Python virtual environment and caching artifact files
.venv/
__pycache__/
*.pyc
.viminfo

# Block all automated agent and captain runtime logs
logs/agents/
logs/public-ready.log

# Exceptions: Allow tracking of foundational documentation/blueprints
!logs/captains/**/*.md

# Rust build output and local FleetCore runtime state
target/
fleetcore/target/
data/fleetcore/
data/living-fleet/
data/world-intake.sqlite3*
logs/fleetcore-serve.log
logs/lan-web-server.log
logs/bridge-station-2.1-server.log
logs/bridge-station-3.0-server.log

# Generated 3D assets -- live on disk where they're served (web/), not
# tracked in git. Regenerate or re-copy onto whatever box serves them.
web/assets/models/*.glb
